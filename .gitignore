.venv/
__pycache__/

# Generated GUI render artifacts from the opt-in UI test suite (tests_ui/).
tests_ui/_artifacts/
# pytest-textual-snapshot's HTML report (written to the repo root on a UI run).
snapshot_report.html

# Editor, agent, and tool caches (kept self-contained so a fresh clone does not
# rely on a contributor's global gitignore).
/.idea/
/.claude/
*.egg-info/
.pytest_cache/
.ruff_cache/

# coverage.py data, combine fragments, and HTML report.
.coverage
.coverage.*
htmlcov/
coverage.xml

# mutmut (mutation testing) result cache. The only artifact a normal
# `scripts/run_mutation.sh` run writes; delete it to force a full re-run.
.mutmut-cache
